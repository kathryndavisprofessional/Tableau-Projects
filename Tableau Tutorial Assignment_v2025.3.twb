      <aliases enabled='yes' />
      <column caption='Order Profitable?' datatype='boolean' name='[Calculation_0031117816999938]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='/*&#13;&#10;Calculate Profit at order level.&#13;&#10;If greater than zero, the order is profitable&#13;&#10;*/&#13;&#10;{ FIXED [Order ID]:SUM([Profit])}&gt;0' />
        <aliases>
          <alias key='false' value='Unprofitable' />
          <alias key='true' value='Profitable' />
        </aliases>
      </column>
      <column caption='Profit Per Order' datatype='real' name='[Calculation_0031117823311875]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Sum([Profit])/countd([Order ID])' />
      </column>
      <column caption='Sales Per Customer' datatype='real' name='[Calculation_0031117823582212]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Sales])/countd([Customer Name])' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
